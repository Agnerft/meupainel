# Dominios
PUBLIC_BASE_DOMAIN=example.com
N8N_HOST=n8n.example.com
EVOLUTION_HOST=evo.example.com
ORCHESTRATOR_HOST=api.example.com
ADMIN_UI_HOST=painel.example.com

# Proxy
NPM_ADMIN_EMAIL=admin@example.com

# Banco principal: n8n + backend
POSTGRES_USER=app
POSTGRES_PASSWORD=change-me-main-db
POSTGRES_DB=app

# Banco Evolution API
EVOLUTION_POSTGRES_USER=evolution
EVOLUTION_POSTGRES_PASSWORD=change-me-evolution-db
EVOLUTION_POSTGRES_DB=evolution

# Redis
REDIS_PASSWORD=change-me-redis

# n8n
N8N_ENCRYPTION_KEY=change-me-32-plus-random-chars
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me-n8n-login
N8N_PROTOCOL=https
WEBHOOK_URL=https://n8n.example.com/
GENERIC_TIMEZONE=America/Sao_Paulo

# Evolution API
EVOLUTION_API_KEY=change-me-evolution-api-key
EVOLUTION_SERVER_URL=https://evo.example.com
EVOLUTION_INSTANCE_NAME=ads
CONFIG_SESSION_PHONE_VERSION=2.3000.1043458542
WEB_VERSION=2.3000.1043458542

# Backend orquestrador
ORCHESTRATOR_PORT=3000
ORCHESTRATOR_WEBHOOK_SECRET=change-me-webhook-secret
UI_ADMIN_TOKEN=change-me-admin-panel-token
OPENAI_MODEL=gpt-4.1-mini
OPENAI_API_KEY=replace-with-openai-api-key
ADS_TAX_RATE=12.15
THE_BEST_API_KEY=replace-with-the-best-api-key
THE_BEST_PER_USER_API_KEYS_JSON={}
THE_BEST_TIMEZONE_OFFSET=-3
THE_BEST_MAX_PAGES=120
